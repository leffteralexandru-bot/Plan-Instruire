# Supabase (opțional) — sincronizare cloud
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth Supabase (opțional) — necesită utilizatori creați în Supabase Auth
VITE_USE_SUPABASE_AUTH=false

# Bitrix24
VITE_BITRIX_PORTAL_URL=https://artgranit.bitrix24.ro
# Incoming webhook REST (read-only deal/task)
VITE_BITRIX_WEBHOOK_URL=

# Push PWA (opțional, viitor)
# VITE_VAPID_PUBLIC_KEY=

# Email alerte HR — destinatar draft mailto + trimitere automată
VITE_HR_ALERT_EMAIL=e.vasilescu@artgranit.ro
# Secret partajat client ↔ API (aceeași valoare ca HR_ALERT_API_SECRET pe Vercel)
VITE_HR_ALERT_API_SECRET=
# Opțional — dacă API-ul e pe alt domeniu
# VITE_API_BASE_URL=

# --- Variabile DOAR pe Vercel (serverless), NU în client ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=artGRANIT HR <hr@artgranit.ro>
# HR_ALERT_EMAIL=e.vasilescu@artgranit.ro
# HR_ALERT_API_SECRET=generati-un-secret-lung
# SUPABASE_SERVICE_ROLE_KEY=... (pentru cron zilnic)
# CRON_SECRET=generati-un-alt-secret
